{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "local-path-exporter values",
  "type": "object",
  "properties": {
    "nameOverride": { "type": "string" },
    "fullnameOverride": { "type": "string" },
    "image": {
      "type": "object",
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] },
        "tag": { "type": "string" }
      },
      "required": ["repository", "pullPolicy"],
      "additionalProperties": false
    },
    "config": {
      "type": "object",
      "properties": {
        "storagePath": { "type": "string", "minLength": 1 },
        "metricTemplate": { "type": "string", "minLength": 1 },
        "refreshIntervalSeconds": { "type": "integer", "minimum": 1 },
        "hostPathType": { "type": "string" }
      },
      "required": ["storagePath", "metricTemplate", "refreshIntervalSeconds"],
      "additionalProperties": false
    },
    "service": {
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "name": { "type": "string" },
        "annotations": { "type": "object" }
      },
      "required": ["type", "port", "name"],
      "additionalProperties": false
    },
    "serviceMonitor": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "labels": { "type": "object" },
        "interval": { "type": "string" },
        "scrapeTimeout": { "type": "string" },
        "matchNamespace": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "resources": { "type": "object" },
    "securityContext": { "type": "object" },
    "containerSecurityContext": { "type": "object" },
    "livenessProbe": { "type": "object" },
    "readinessProbe": { "type": "object" },
    "volumeMounts": {
      "type": "object",
      "properties": {
        "readOnly": { "type": "boolean" }
      }
    },
    "nodeSelector": { "type": "object" },
    "tolerations": { "type": "array" },
    "affinity": { "type": "object" }
  }
}
